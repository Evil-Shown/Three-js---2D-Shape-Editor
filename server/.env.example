PORT=3001
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=gsap_editor

REDIS_URL=redis://127.0.0.1:6379
SHAPE_JOB_LIST_KEY=gsap:shape-processing:jobs

# Local editor: trust headers without JWT
AUTH_DISABLED=true

# Production ERP: require Bearer JWT
# AUTH_DISABLED=false
# JWT_SECRET=change-me-use-long-random-secret
# JWT_CLAIM_USER_ID=sub
# JWT_CLAIM_ORG_ID=organization_id
# JWT_CLAIM_PROJECT_ID=project_id

CORS_ORIGIN=http://localhost:5173

BULLMQ_SHAPE_QUEUE=shape-processing
BULLMQ_ENABLE_ACK_WORKER=true
